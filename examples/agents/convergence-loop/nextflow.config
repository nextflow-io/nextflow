plugins {
    id 'nf-agent@0.1.0'
}

// The labelled dataset read by the `score_threshold` tool. Fixed here (not an
// agent input) so every tool call is just {"threshold": <x>}.
params.scores = "${projectDir}/scores.txt"

// No container runtime needed: `score_threshold` is a local `exec:` process that
// reads the dataset and computes F1 in-process.
