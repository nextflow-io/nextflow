set -e

$NXF_RUN | tee stdout
[[ $(grep INFO .nextflow.log | grep -c 'Submitted process > CHECK_SAMPLE') == 1 ]]
grep 'record input localized' stdout

TASK_DIR=$($NXF_CMD log last -F "process == 'CHECK_SAMPLE'")
grep "cat 'input.txt' > out.txt" "$TASK_DIR/.command.sh"
test -e "$TASK_DIR/input.txt"

$NXF_RUN -resume | tee stdout
[[ $(grep INFO .nextflow.log | grep -c 'Cached process > CHECK_SAMPLE') == 1 ]]
grep 'record input localized' stdout