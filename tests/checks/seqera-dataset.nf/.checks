set -e
export NXF_PLUGINS_DEFAULT=nf-tower

# Skip test if Seqera Platform token is missing
if [[ ! $TOWER_ACCESS_TOKEN ]]; then
  echo "Skip seqera-dataset test since TOWER_ACCESS_TOKEN is not available"
  exit 0
fi

#
# run normal mode
#
$NXF_RUN | tee stdout

[[ `grep INFO .nextflow.log | grep -c 'Submitted process > TEST'` == 1 ]] || false
[[ `grep -c 'patient,sex,status,sample,lane,fastq_1,fastq_2' stdout` == 1 ]] || false

