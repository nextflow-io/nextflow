/*
 * Configuration for the "Hello <provider>" demonstration.
 *
 * Enables Docker so each process runs in a base image that ships its package
 * manager, enables the package preview feature, and loads every provider plugin.
 */

// Run each task in its per-process container (see the `container` directives)
docker.enabled = true

// Enable the unified package management preview feature
nextflow.preview.package = true

// Load every package-provider plugin
plugins {
    id 'nf-conda'
    id 'nf-pixi'
    id 'nf-uv'
    id 'nf-nix'
    id 'nf-guix'
    id 'nf-pak'
    id 'nf-install2r'
}

packages {
    provider = 'conda'
    conda {
        channels = ['conda-forge', 'bioconda']
    }
}
