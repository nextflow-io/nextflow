/*
 * Configuration for the unified package-directive demonstration.
 *
 * Enables the preview feature and loads each provider plugin. Each process in
 * package-providers-demo.nf selects its provider via `package ..., provider: ...`.
 */

// Enable the unified package management preview feature
nextflow.preview.package = true

// Load every package-provider plugin
plugins {
    id 'nf-conda'
    id 'nf-pixi'
    id 'nf-uv'
    id 'nf-nix'
    id 'nf-guix'
    id 'nf-pak'
    id 'nf-install2r'
}

// Default provider used when a `package` directive omits `provider:`
packages {
    provider = 'conda'
    conda {
        channels = ['conda-forge', 'bioconda']
    }
}
