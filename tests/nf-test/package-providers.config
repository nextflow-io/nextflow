/*
 * Shared config applied to every package-provider nf-test (via nf-test.config
 * `configFile`). Enables the preview feature and loads all CI-tested provider
 * plugins; each test exercises only its tagged provider, so a CI job needs just
 * that one tool installed (plugins whose tool is absent are skipped).
 */

nextflow.preview.package = true

plugins {
    id 'nf-conda'
    id 'nf-pixi'
    id 'nf-uv'
    id 'nf-nix'
    id 'nf-pak'
    id 'nf-install2r'
}

packages {
    provider = 'conda'
}

conda {
    channels = ['conda-forge', 'bioconda']
}
