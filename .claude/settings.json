{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-editorconfig.sh",
            "timeout": 30,
            "async": true
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/format-idea.sh",
            "timeout": 60,
            "async": true
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-tests.sh",
            "timeout": 300
          },
          {
            "type": "command",
            "if": "Edit(tests/*.nf)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-integration-test.sh",
            "timeout": 600,
            "asyncRewake": true
          },
          {
            "type": "command",
            "if": "Write(tests/*.nf)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-integration-test.sh",
            "timeout": 600,
            "asyncRewake": true
          },
          {
            "type": "command",
            "if": "MultiEdit(tests/*.nf)",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/run-integration-test.sh",
            "timeout": 600,
            "asyncRewake": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-build.sh",
            "timeout": 120
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/check-build.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
